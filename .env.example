# Port for Express API server
PORT=5000

# Node Environment Mode (development or production)
NODE_ENV=development

# PostgreSQL connection string
# (If left empty, backend falls back to local JSON database: D:\GIT-HUB\Ganay\backend\data\db.json)
DATABASE_URL=postgresql://admin:password123@localhost:5432/naghma

# Redis connection string
# (If left empty, backend falls back to local in-memory Cache)
REDIS_URL=redis://localhost:6379

# YouTube Data API v3 Key (Optional)
# (If left empty, backend queries/scrapes YouTube search metadata using yt-dlp flat-search, no API key needed!)
YOUTUBE_API_KEY=
